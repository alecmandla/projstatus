#!/usr/bin/env bash
#
# projstatus — a live, interactive "where am I" dashboard for repos that keep
# their plan as markdown task files on disk, in a Linear-style hierarchy
# (Initiative > Project > Milestone > Issue) of 1–4 folder levels plus a leaf:
#
#   <tasks-root>/<level1>/<level2>/…/TASKS.md   (## <ID>: Title + **Status:** `[x]/[ ]`)
#                                   /GAPS.md    (### GAP-… structured gaps)
#                                   /ISSUES.md  (### ISS-… structured issues)
#
# Folder names are `<prefix><n>-<slug>` (e.g. project-0-foundations). The depth
# and prefixes are auto-detected; selectors compose from the levels' letters
# (P0M1 for project-*/milestone-*, I0P1M2 for a 3-folder-level repo, …).
#
# USAGE
#   projstatus                 the current leaf (the pointer), once
#   projstatus P0M1 | P0       peek at any node: full tokens reach a leaf,
#                              partial tokens show that group's overview
#   projstatus -2 | milestone  altitude view: the current point of development
#                              at that level, among its siblings — level words
#                              match your repo's own labels; -<n> counts from
#                              the top (the leaf is -<levels+1>)
#   projstatus all             the whole tree at a glance (alias: ls)
#   projstatus now             plain-text orientation: the pointer + the first
#                              unfinished task (stable, grep-able — made for
#                              new sessions, scripts, and agents)
#   projstatus watch           the live, interactive pane (aliases: --watch, -w)
#   projstatus pane            open the live pane in a Supacode split (if inside Supacode)
#   projstatus view <sel>      retarget a running pane from another shell
#                              (also: view next / view prev step the pane)
#   projstatus version         print the version (aliases: --version, -v)
#   projstatus update          git-pull the checkout this command runs from
#   projstatus help            this help
#
# In the live pane, click it to focus, then press:
#   n next · p prev · c live pointer · a all · 1-4 altitude · g go to · r refresh · q quit
#
# ADAPTING IT — drop an optional ".projstatus" file at a repo's root to override
# any of these (all have sensible auto-detected defaults):
#   PROJECT_NAME="My Project"      # header label   (default: the repo folder name)
#   TASKS_ROOT="docs/tasks"        # where the level folders live (auto: docs/tasks|tasks|planning/tasks)
#   HIERARCHY="project-:Project:P milestone-:Milestone:M"
#       # ordered outermost→leaf-parent; each level is <folder-prefix>[:<Label>[:<Letter>]]
#       # (label/letter are derived from the prefix when omitted); an optional
#       # @<file>[:<Label>[:<Letter>]] entry names the leaf (default @TASKS.md:Task:T)
#   POINTER_FILE="AGENTS.md"       # file holding the pointer line
#   POINTER_PATTERN="Current pointer:"
#   INBOX="docs/ISSUES_INBOX.md"   # raw issue inbox (auto-detected)
#   TASK_RE='^## P[0-9]+M[0-9]+T[0-9]+:'   GAP_RE='^### GAP-'   ISS_RE='^### ISS-'
#       # TASK_RE's default is derived from the hierarchy's letters
#   WIDTH_CAP=72                   REFRESH=4
# The pre-HIERARCHY two-level keys (OUTER_PREFIX/INNER_PREFIX, OUTER_LABEL/…,
# OUTER_LETTER/…) still work and imply a two-level hierarchy.
# With no pointer line anywhere, "current" auto-resolves to the first leaf
# that still has unfinished tasks.
#
set -uo pipefail

VERSION="1.0.0"

# --- locate the project root (the git repo we're standing in) ----------------
find_root() {
  local r; r="$(git rev-parse --show-toplevel 2>/dev/null)"; [ -n "$r" ] && { printf '%s' "$r"; return; }
  local d="$PWD"
  while [ "$d" != "/" ]; do
    for m in .projstatus AGENTS.md docs/tasks tasks; do [ -e "$d/$m" ] && { printf '%s' "$d"; return; }; done
    d="$(dirname "$d")"
  done
  printf '%s' "$PWD"
}
ROOT="$(find_root)"; cd "$ROOT"

# --- colors (only when stdout is a tty) --------------------------------------
if [ -t 1 ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; RST=$'\033[0m'
  GRN=$'\033[32m'; YEL=$'\033[33m'; CYN=$'\033[36m'; MAG=$'\033[35m'; RED=$'\033[31m'
else
  BOLD=""; DIM=""; RST=""; GRN=""; YEL=""; CYN=""; MAG=""; RED=""
fi

lc()        { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }
uc()        { printf '%s' "$1" | tr '[:lower:]' '[:upper:]'; }
titlecase() { awk '{for(i=1;i<=NF;i++)$i=toupper(substr($i,1,1)) substr($i,2)}1'; }

# --- configuration: source the optional .projstatus, then fill in defaults ----
[ -f "$ROOT/.projstatus" ] && . "$ROOT/.projstatus" 2>/dev/null
PROJECT_NAME="${PROJECT_NAME:-$(basename "$ROOT" | sed 's/[-_]/ /g' | titlecase)}"
if [ -z "${TASKS_ROOT:-}" ]; then
  for c in docs/tasks tasks planning/tasks; do [ -d "$ROOT/$c" ] && { TASKS_ROOT="$c"; break; }; done
fi
TASKS_ROOT="${TASKS_ROOT:-docs/tasks}"
POINTER_FILE="${POINTER_FILE:-AGENTS.md}"
POINTER_PATTERN="${POINTER_PATTERN:-Current pointer:}"
if [ -z "${INBOX:-}" ]; then
  for c in docs/ISSUES_INBOX.md ISSUES_INBOX.md docs/ISSUES.md; do [ -f "$ROOT/$c" ] && { INBOX="$c"; break; }; done
fi
INBOX="${INBOX:-docs/ISSUES_INBOX.md}"
GAP_RE="${GAP_RE:-^### GAP-}"
ISS_RE="${ISS_RE:-^### ISS-}"
WIDTH_CAP="${WIDTH_CAP:-72}"
REFRESH="${REFRESH:-4}"

# --- the hierarchy: 1–4 folder levels + a leaf (task headers in TASKS.md) ----
# Level i lives in PFX_i / LBL_i / LTR_i (bash 3.2: no associative arrays).
# Sources, first match wins: HIERARCHY key · legacy OUTER_*/INNER_* keys ·
# auto-detect from the folder tree · the classic project-/milestone- default.
TASKS_FILE="TASKS.md"
TASK_LABEL="${TASK_LABEL:-Task}"
TASK_LETTER="$(uc "${TASK_LETTER:-T}")"
NLEV=0

set_level() { eval "PFX_$1=\"\$2\"; LBL_$1=\"\$3\"; LTR_$1=\"\$(uc \"\$4\")\""; }
pfx()    { eval "printf '%s' \"\$PFX_$1\""; }
lbl()    { eval "printf '%s' \"\$LBL_$1\""; }
ltr()    { eval "printf '%s' \"\$LTR_$1\""; }

derive_label() { printf '%s' "$1" | sed 's/[-_]*$//; s/[-_]/ /g' | titlecase; }

pick_letter() {  # pick_letter <label> <used-letters> — first unused letter of the label
  local w c i=1; w="$(uc "$1" | tr -cd 'A-Z')"
  while [ "$i" -le "${#w}" ]; do
    c="$(printf '%s' "$w" | cut -c"$i")"
    case "$2" in *"$c"*) ;; *) printf '%s' "$c"; return ;; esac
    i=$((i+1))
  done
  for c in X Y Z Q K J V W; do case "$2" in *"$c"*) ;; *) printf '%s' "$c"; return ;; esac; done
  printf 'L'
}

nfields() { printf '%s' "$1" | awk -F: '{print NF}'; }
field()   { printf '%s' "$1" | cut -d: -f"$2"; }

parse_hierarchy() {
  local tok body label letter prefix used="$TASK_LETTER"
  for tok in $HIERARCHY; do
    case "$tok" in
      @*)
        body="${tok#@}"
        TASKS_FILE="$(field "$body" 1)"
        [ "$(nfields "$body")" -ge 2 ] && TASK_LABEL="$(field "$body" 2)"
        [ "$(nfields "$body")" -ge 3 ] && TASK_LETTER="$(uc "$(field "$body" 3)")"
        ;;
      *)
        prefix="$(field "$tok" 1)"
        if [ "$(nfields "$tok")" -ge 2 ]; then label="$(field "$tok" 2)"; else label="$(derive_label "$prefix")"; fi
        if [ "$(nfields "$tok")" -ge 3 ]; then letter="$(field "$tok" 3)"; else letter="$(pick_letter "$label" "$used")"; fi
        used="$used$(uc "$letter")"
        NLEV=$((NLEV+1)); set_level "$NLEV" "$prefix" "$label" "$letter"
        ;;
    esac
  done
}

autodetect_hierarchy() {  # infer depth + prefixes from the first TASKS.md found
  local leaf rel depth i seg prefix label letter used="$TASK_LETTER"
  leaf="$(find "$TASKS_ROOT" -mindepth 2 -maxdepth 5 -name "$TASKS_FILE" 2>/dev/null | sort | head -1)"
  [ -z "$leaf" ] && return 1
  rel="${leaf#$TASKS_ROOT/}"
  depth=$(printf '%s' "$rel" | awk -F/ '{print NF-1}')
  { [ "$depth" -ge 1 ] && [ "$depth" -le 4 ]; } || return 1
  i=1
  while [ "$i" -le "$depth" ]; do
    seg="$(printf '%s' "$rel" | cut -d/ -f"$i")"
    prefix="$(printf '%s' "$seg" | sed 's/[0-9].*$//')"
    [ -n "$prefix" ] || return 1
    label="$(derive_label "$prefix")"
    letter="$(pick_letter "$label" "$used")"; used="$used$letter"
    set_level "$i" "$prefix" "$label" "$letter"
    i=$((i+1))
  done
  NLEV="$depth"
}

if [ -n "${HIERARCHY:-}" ]; then
  parse_hierarchy
elif [ -n "${OUTER_PREFIX:-}${OUTER_LABEL:-}${OUTER_LETTER:-}${INNER_PREFIX:-}${INNER_LABEL:-}${INNER_LETTER:-}" ]; then
  NLEV=2
  set_level 1 "${OUTER_PREFIX:-project-}"   "${OUTER_LABEL:-Project}"   "${OUTER_LETTER:-P}"
  set_level 2 "${INNER_PREFIX:-milestone-}" "${INNER_LABEL:-Milestone}" "${INNER_LETTER:-M}"
else
  autodetect_hierarchy || {
    NLEV=2
    set_level 1 "project-"   "Project"   "P"
    set_level 2 "milestone-" "Milestone" "M"
  }
fi

ID_RE=""; _i=1
while [ "$_i" -le "$NLEV" ]; do ID_RE="${ID_RE}$(ltr "$_i")[0-9]+"; _i=$((_i+1)); done
TASK_RE="${TASK_RE:-^## ${ID_RE}${TASK_LETTER}[0-9]+:}"
LEAF_LBL="$(lbl "$NLEV")"
NAME_DISPLAY="$(uc "$PROJECT_NAME")"

sel_example() {  # a plausible selector, e.g. P0M1 / I0P1M2
  local i=1 out=""
  while [ "$i" -le "$NLEV" ]; do out="$out$(ltr "$i")$((i-1))"; i=$((i+1)); done
  printf '%s' "$out"
}

# --- slug parsing (honors the per-level prefixes) -----------------------------
slug_num()  { printf '%s' "$2" | sed -E "s/^$(pfx "$1")([0-9]+)-.*/\1/"; }
slug_name() { printf '%s' "$2" | sed -E "s/^$(pfx "$1")[0-9]+-//; s/-/ /g"; }

# env overrides — PROJSTATUS_*; the historical MNEMO_* names still work
PROJSTATUS_COLS="${PROJSTATUS_COLS:-${MNEMO_COLS:-}}"
PROJSTATUS_NO_CLEAR="${PROJSTATUS_NO_CLEAR:-${MNEMO_NO_CLEAR:-}}"
PROJSTATUS_FORCE_TTY="${PROJSTATUS_FORCE_TTY:-${MNEMO_FORCE_TTY:-}}"

GITDIR="$(git rev-parse --git-dir 2>/dev/null || echo .git)"
[ -d "$GITDIR" ] && VIEW_FILE="$GITDIR/projstatus-view" || VIEW_FILE="$ROOT/.projstatus-view"
PANE=0   # set to 1 in --watch so footers show key hints instead of command hints
STATUS_DONE='^[[:space:]]*-[[:space:]]*\*\*Status:\*\*[[:space:]]*`\[x\]'

rule()      { printf '%s%s%s\n' "$DIM" "$(printf '─%.0s' $(seq 1 "$1"))" "$RST"; }
cols_now()  { local c="${PROJSTATUS_COLS:-}"; [ -z "$c" ] && c=$(tput cols 2>/dev/null || echo 56); [ "$c" -gt "$WIDTH_CAP" ] && c="$WIDTH_CAP"; printf '%s' "$c"; }

bar() {
  local d=$1 t=$2 w=$3 f i out=""
  if [ "$t" -gt 0 ]; then f=$(( d * w / t )); else f=0; fi
  for ((i=0;i<w;i++)); do if [ "$i" -lt "$f" ]; then out="${out}▓"; else out="${out}░"; fi; done
  printf '%s' "$out"
}

# --- walking the tree ---------------------------------------------------------
lvl_dirs()  { find "$TASKS_ROOT" -mindepth "$1" -maxdepth "$1" -type d -name "$(pfx "$1")*" 2>/dev/null | sort -V; }
leaf_dirs() { lvl_dirs "$NLEV"; }
kids() {  # child dirs of $1 at level $2
  find "$1" -mindepth 1 -maxdepth 1 -type d -name "$(pfx "$2")*" 2>/dev/null | sort -V
}
dir_level() { printf '%s' "${1#$TASKS_ROOT/}" | awk -F/ '{print NF}'; }
path_seg()  { printf '%s' "${1#$TASKS_ROOT/}" | cut -d/ -f"$2"; }
ancestor_at() {  # the level-$2 ancestor of dir $1
  local out="$TASKS_ROOT" i=1
  while [ "$i" -le "$2" ]; do out="$out/$(path_seg "$1" "$i")"; i=$((i+1)); done
  printf '%s' "$out"
}

count_file() {
  local file="$1" hdr="$2" t dn
  t=$(grep -cE "$hdr" "$file" 2>/dev/null); t=${t:-0}
  dn=$(grep -cE "$STATUS_DONE" "$file" 2>/dev/null); dn=${dn:-0}
  printf '%s %s' "$dn" "$t"
}
count_tree() {  # done/total across every TASKS.md under $1
  local dn tt
  dn=$(find "$1" -name "$TASKS_FILE" -exec grep -hcE "$STATUS_DONE" {} + 2>/dev/null | awk '{s+=$1}END{print s+0}')
  tt=$(find "$1" -name "$TASKS_FILE" -exec grep -hcE "$TASK_RE" {} + 2>/dev/null | awk '{s+=$1}END{print s+0}')
  printf '%s %s' "$dn" "$tt"
}

# --- pointer -------------------------------------------------------------------
# the pointer slug: explicit line if present, else first unfinished leaf
pointer_slug() {
  # the first backtick span on the pointer line (pointer lines may quote more than one)
  grep -m1 "$POINTER_PATTERN" "$POINTER_FILE" 2>/dev/null | sed -n 's/[^`]*`\([^`]*\)`.*/\1/p'
}
first_unfinished_leaf() {
  local d dn tt
  while IFS= read -r d; do
    set -- $(count_file "$d/$TASKS_FILE" "$TASK_RE"); dn=$1; tt=$2
    if [ "${tt:-0}" -gt 0 ] && [ "$dn" -lt "$tt" ]; then printf '%s' "$d"; return; fi
  done < <(leaf_dirs)
  leaf_dirs | tail -1
}
pointer_state() {
  local line; line=$(grep -m1 "$POINTER_PATTERN" "$POINTER_FILE" 2>/dev/null)
  if [ -n "$line" ]; then printf '%s' "$line" | sed -E 's/.*—[[:space:]]*//; s/\*\*.*$//; s/[*.[:space:]]*$//'
  else printf 'you are here (first unfinished %s)' "$(lc "$LEAF_LBL")"; fi
}
slug_dir() { find "$TASKS_ROOT" -maxdepth "$NLEV" -type d -name "$1" 2>/dev/null | head -1; }
ptr_leaf() {  # the leaf the pointer denotes; a group pointer descends to its first unfinished leaf
  local d lvl c dn tt slug
  slug="$(pointer_slug)"
  [ -n "$slug" ] && d="$(slug_dir "$slug")" || d=""
  [ -z "$d" ] && { first_unfinished_leaf; return; }
  lvl="$(dir_level "$d")"
  [ "$lvl" -ge "$NLEV" ] && { printf '%s' "$d"; return; }
  while IFS= read -r c; do
    set -- $(count_file "$c/$TASKS_FILE" "$TASK_RE"); dn=$1; tt=$2
    if [ "${tt:-0}" -gt 0 ] && [ "$dn" -lt "$tt" ]; then printf '%s' "$c"; return; fi
  done < <(find "$d" -mindepth $((NLEV-lvl)) -maxdepth $((NLEV-lvl)) -type d -name "$(pfx "$NLEV")*" 2>/dev/null | sort -V)
  find "$d" -mindepth $((NLEV-lvl)) -maxdepth $((NLEV-lvl)) -type d -name "$(pfx "$NLEV")*" 2>/dev/null | sort -V | head -1
}

dir_token() {  # P0M2-style token for a dir at any level
  local rel="${1#$TASKS_ROOT/}" out="" i=1 seg oldifs="$IFS"
  IFS=/
  for seg in $rel; do out="$out$(ltr "$i")$(slug_num "$i" "$seg")"; i=$((i+1)); done
  IFS="$oldifs"
  printf '%s' "$out"
}
nums_dir() {  # nums_dir <n1> [n2 …] → the dir those level numbers name
  local g="$TASKS_ROOT" i=1 n
  for n in "$@"; do g="$g/$(pfx "$i")${n}-*"; i=$((i+1)); done
  ls -d $g 2>/dev/null | head -1
}

# --- selector resolution -> "KIND<TAB>ARG" -----------------------------------
classify() {  # an existing dir → LEAF (leaf level) | GROUP (has children) | SUMMARY
  local d="$1" lvl; lvl="$(dir_level "$d")"
  if [ "$lvl" -ge "$NLEV" ]; then printf 'LEAF\t%s' "$d"
  elif [ -n "$(kids "$d" $((lvl+1)) | head -1)" ]; then printf 'GROUP\t%s' "$d"
  else printf 'SUMMARY\t%s' "$d"; fi
}

level_sel() {  # altitude selector ("-2", "milestone", "task") → level 1..NLEV+1, or ""
  local s="$1" i=1
  case "$s" in
    -[1-9])
      s="${s#-}"
      [ "$s" -le $((NLEV+1)) ] && printf '%s' "$s"
      return ;;
  esac
  while [ "$i" -le "$NLEV" ]; do
    [ "$s" = "$(lc "$(lbl "$i")")" ] && { printf '%s' "$i"; return; }
    i=$((i+1))
  done
  [ "$s" = "$(lc "$TASK_LABEL")" ] && printf '%s' $((NLEV+1))
}

resolve() {
  local sel; sel="$(lc "$1")"
  local d i l num rest nums k
  case "$sel" in
    ""|pointer)
      d="$(ptr_leaf)"
      [ -n "$d" ] && printf 'LEAF\t%s' "$d" || printf 'NONE\tno %s folders found under %s' "$(lc "$LEAF_LBL")" "$TASKS_ROOT"; return ;;
    ls|list|all) printf 'LIST\t'; return ;;
    next|prev) resolve_nav "$sel"; return ;;
  esac
  # altitude selectors: the current point of development, viewed at level k
  k="$(level_sel "$sel")"
  if [ -n "$k" ]; then
    if [ "$k" -eq 1 ]; then printf 'TOP\t%s' "$TASKS_ROOT"; return; fi
    d="$(ptr_leaf)"
    [ -z "$d" ] && { printf 'NONE\tno %s folders found under %s' "$(lc "$LEAF_LBL")" "$TASKS_ROOT"; return; }
    if [ "$k" -gt "$NLEV" ]; then printf 'LEAF\t%s' "$d"
    else printf 'GROUP\t%s' "$(ancestor_at "$d" $((k-1)))"; fi
    return
  fi
  # letter-number tokens, outermost first: L1n[L2n[…]] — full or partial depth
  rest="$sel"; i=0; nums=""
  while [ "$i" -lt "$NLEV" ] && [ -n "$rest" ]; do
    l="$(lc "$(ltr $((i+1)))")"
    case "$rest" in
      "$l"[0-9]*)
        i=$((i+1))
        rest="${rest#$l}"
        num="$(printf '%s' "$rest" | sed 's/[^0-9].*//')"
        rest="${rest#$num}"
        nums="$nums $num" ;;
      *) break ;;
    esac
  done
  if [ -n "$nums" ] && [ -z "$rest" ]; then
    d="$(nums_dir $nums)"
    if [ -n "$d" ]; then classify "$d"; return; fi
    set -- $nums
    local k=$# last pn="" pd j=1
    eval "last=\${$k}"
    if [ "$k" -eq 1 ]; then printf 'NONE\tno %s %s' "$(lc "$(lbl 1)")" "$last"; return; fi
    while [ "$j" -lt "$k" ]; do eval "pn=\"\$pn \${$j}\""; j=$((j+1)); done
    pd="$(nums_dir $pn)"
    if [ -n "$pd" ]; then printf 'NONE\tno %s %s under %s (try %s)' "$(lc "$(lbl "$k")")" "$last" "$(dir_token "$pd")" "$(dir_token "$pd")"
    else printf 'NONE\tno match for %s' "$(uc "$sel")"; fi
    return
  fi
  # a raw folder slug at any level
  i=1
  while [ "$i" -le "$NLEV" ]; do
    case "$sel" in
      "$(lc "$(pfx "$i")")"*)
        d="$(slug_dir "$1")"
        [ -n "$d" ] && classify "$d" || printf 'NONE\tno %s %s' "$(lc "$(lbl "$i")")" "$1"
        return ;;
    esac
    i=$((i+1))
  done
  printf 'NONE\tunknown selector: %s' "$1"
}

resolve_nav() {  # next/prev among siblings at the current view's level
  local dirn="$1" cur base lvl idx=0 n=0 d
  cur="$(cat "$VIEW_FILE" 2>/dev/null)"; [ -z "$cur" ] && cur="pointer"
  case "$cur" in pointer|ls) base="$(ptr_leaf)" ;; *) base="$(_sel_to_dir "$cur")" ;; esac
  [ -z "$base" ] && base="$(ptr_leaf)"
  [ -z "$base" ] && { printf 'NONE\tnothing to step through under %s' "$TASKS_ROOT"; return; }
  lvl="$(dir_level "$base")"
  while IFS= read -r d; do n=$((n+1)); [ "$d" = "$base" ] && idx=$n; done < <(lvl_dirs "$lvl")
  if [ "$dirn" = "next" ]; then idx=$((idx+1)); else idx=$((idx-1)); fi
  [ "$idx" -lt 1 ] && idx=1; [ "$idx" -gt "$n" ] && idx="$n"
  d="$(lvl_dirs "$lvl" | sed -n "${idx}p")"
  [ -n "$d" ] && classify "$d" || printf 'NONE\tnothing there'
}
_sel_to_dir() {
  local r; r="$(resolve "$1")"
  case "${r%%	*}" in LEAF|GROUP|SUMMARY) printf '%s' "${r#*	}" ;; *) : ;; esac
}

write_view() {
  local sel="$1" r kind arg tok k
  r="$(resolve "$sel")"; kind="${r%%	*}"; arg="${r#*	}"
  [ "$kind" = "NONE" ] && return 1
  case "$kind" in
    LEAF|GROUP|SUMMARY) tok="$(dir_token "$arg")" ;;
    TOP)  tok="-1" ;;
    LIST) tok="ls" ;;
    *) tok="$sel" ;;
  esac
  # altitude selectors stay live — the stored token re-anchors at the pointer each refresh
  k="$(level_sel "$(lc "$sel")")"; [ -n "$k" ] && tok="-$k"
  [ "$(lc "$sel")" = "pointer" ] && tok="pointer"
  printf '%s\n' "$tok" > "$VIEW_FILE"
}

# --- item list renderer (tasks / gaps / issues) ------------------------------
render_items() {
  local file="$1" hdr="$2" idw="$3" tagf="${4:-}" cols; cols=$(cols_now)
  awk -v g="$GRN" -v d="$DIM" -v y="$YEL" -v rd="$RED" -v r="$RST" \
      -v hdr="$hdr" -v tagf="$tagf" -v idw="$idw" -v maxw="$(( cols - idw - 5 ))" '
    function trunc(s,n){ return (length(s)>n) ? substr(s,1,n-1) "…" : s }
    function tcol(t){ if(t ~ /[Cc]rit|[Hh]igh/) return rd; if(t ~ /[Mm]ed/) return y; return d }
    $0 ~ hdr {
      h=$0; sub(/^#+[ ]+/,"",h); c=index(h,":"); cur=substr(h,1,c-1);
      title[cur]=substr(h,c+2); ord[++n]=cur; seen[cur]=0; xd[cur]=0; tag[cur]=""; next
    }
    tagf!="" && cur!="" && tag[cur]=="" && $0 ~ ("\\*\\*" tagf ":\\*\\*") {
      t=$0; sub(/.*:\*\*[ ]*/,"",t); sub(/[ `].*/,"",t); tag[cur]=t
    }
    cur!="" && seen[cur]==0 && $0 ~ /\*\*Status:\*\*/ { seen[cur]=1; xd[cur]=($0 ~ /\[x\]/) }
    # sub-issues: checklist lines inside the section (the Status line is "- **…", not "- [")
    cur!="" && $0 ~ /^[[:space:]]*- \[[ xX]\]/ {
      st[cur]++; if ($0 ~ /^[[:space:]]*- \[[xX]\]/) sd[cur]++
    }
    END {
      for(i=1;i<=n;i++){ id=ord[i]; tg=""; sfx=""; w=maxw;
        if(!xd[id] && tag[id]!="") tg=tcol(tag[id]) "[" substr(tag[id],1,4) "] " r;
        if(!xd[id] && st[id]>0){ p=sprintf("%d/%d", sd[id]+0, st[id]); w-=length(p)+1; sfx=" " d p r }
        if(xd[id]) printf "  %s●%s %-*s %s%s%s\n", g,r, idw, id, g, trunc(title[id],maxw), r;
        else       printf "  %s○%s %-*s %s%s%s\n", d,r, idw, id, tg, trunc(title[id],w), sfx;
      }
    }' "$file"
}

inbox_open() {
  [ -f "$INBOX" ] || { printf '0'; return; }
  awk -v round="^## ${ID_RE}" '
    $0 ~ round { inround=1; next }
    /^## /     { inround=0 }
    inround && /^- / && $0 !~ /Converted to/ { c++ }
    END { print c+0 }' "$INBOX"
}

# ============================ views ==========================================
header() {
  local cols pad; cols=$(cols_now)
  pad=$(( cols - 2 - ${#NAME_DISPLAY} - 3 - ${#1} - 8 )); [ "$pad" -lt 1 ] && pad=1
  printf '%s  %s ▸ %s%s%*s%s\n' "$BOLD$CYN" "$NAME_DISPLAY" "$1" "$RST" "$pad" "" "${DIM}$(date +%H:%M:%S)$RST"
  rule $(( cols - 2 ))
}

nav_hint() {
  if [ "$PANE" = 1 ]; then
    local k="$CYN" d="$DIM" r="$RST"
    echo ""
    echo "  ${d}keys${r}  ${k}n${r}${d} next  ${k}p${r}${d} prev  ${k}c${r}${d} live  ${k}a${r}${d} all  ${k}1-$((NLEV+1))${r}${d} altitude  ${k}g${r}${d} go to  ${k}q${r}${d} quit${r}"
  else
    printf '  %s↹ run:  projstatus <%s|-2|all>   ·   projstatus view <sel> moves the pane%s\n' "$DIM" "$(sel_example)" "$RST"
  fi
}

footer_nav() {
  local viewtok="$1" ptok="$2" cols; cols=$(cols_now)
  printf '\n'; rule $(( cols - 2 ))
  printf '  %sview %s%s%s   pointer ◆ %s%s\n' "$DIM" "$RST$MAG" "$viewtok" "$DIM" "$ptok" "$RST"
  nav_hint
}

render_inbox_line() {
  local n; n="$(inbox_open)"
  [ "$n" -gt 0 ] && printf '\n  %s⚠ inbox: %s untriaged note(s)%s\n' "$YEL" "$n" "$RST"
  return 0
}

render_leaf() {
  local dir="$1" cols; cols=$(cols_now)
  local i seg tasks gaps issues
  i=1
  while [ "$i" -lt "$NLEV" ]; do
    seg="$(path_seg "$dir" "$i")"
    printf '  %s%s %s%s · %s\n' "$BOLD" "$(lbl "$i")" "$(slug_num "$i" "$seg")" "$RST" "$(slug_name "$i" "$seg" | titlecase)"
    i=$((i+1))
  done
  seg="$(path_seg "$dir" "$NLEV")"
  printf '  %s%s %s%s — %s%s%s\n' "$BOLD" "$LEAF_LBL" "$(slug_num "$NLEV" "$seg")" "$RST" "$MAG" "$(slug_name "$NLEV" "$seg")" "$RST"
  tasks="$dir/$TASKS_FILE"; gaps="$dir/GAPS.md"; issues="$dir/ISSUES.md"

  local ptr_dir ptr_idx=0 my_idx=0 n=0 rel d
  ptr_dir="$(ptr_leaf)"
  while IFS= read -r d; do
    n=$((n+1)); [ "$d" = "$ptr_dir" ] && ptr_idx=$n; [ "$d" = "$dir" ] && my_idx=$n
  done < <(leaf_dirs)
  if [ "$dir" = "$ptr_dir" ]; then rel="◆ current pointer — $(pointer_state)"
  elif [ "$my_idx" -lt "$ptr_idx" ]; then rel="↩ past $(lc "$LEAF_LBL")"
  else rel="↪ upcoming $(lc "$LEAF_LBL")"; fi
  printf '  %s%s%s\n\n' "$DIM" "$rel" "$RST"

  if [ -f "$tasks" ]; then
    set -- $(count_file "$tasks" "$TASK_RE"); local td=$1 tt=$2
    printf '  %sTasks%s%*s%s%s/%s done%s\n' "$BOLD" "$RST" $(( cols - 7 - ${#td} - ${#tt} - 6 )) "" "$DIM" "$td" "$tt" "$RST"
    rule $(( cols - 2 )); render_items "$tasks" "$TASK_RE" 8 ""
  fi
  if [ -f "$gaps" ] && grep -qE "$GAP_RE" "$gaps"; then
    set -- $(count_file "$gaps" "$GAP_RE"); local gd=$1 gt=$2
    printf '\n  %sGaps%s%*s%s%s/%s done%s\n' "$BOLD" "$RST" $(( cols - 6 - ${#gd} - ${#gt} - 6 )) "" "$DIM" "$gd" "$gt" "$RST"
    rule $(( cols - 2 )); render_items "$gaps" "$GAP_RE" 11 "Severity"
  fi
  if [ -f "$issues" ] && grep -qE "$ISS_RE" "$issues"; then
    set -- $(count_file "$issues" "$ISS_RE"); local isd=$1 ist=$2
    printf '\n  %sIssues%s%*s%s%s/%s done%s\n' "$BOLD" "$RST" $(( cols - 8 - ${#isd} - ${#ist} - 6 )) "" "$DIM" "$isd" "$ist" "$RST"
    rule $(( cols - 2 )); render_items "$issues" "$ISS_RE" 11 "Priority"
  fi

  local pd pt parent agg
  if [ "$NLEV" -ge 2 ]; then
    parent="$(dirname "$dir")"
    agg="$(lbl $((NLEV-1))) $(slug_num $((NLEV-1)) "$(basename "$parent")")"
  else
    parent="$TASKS_ROOT"; agg="Overall"
  fi
  pd=$(grep -hcE "$STATUS_DONE" "$parent"/*/"$TASKS_FILE" 2>/dev/null | awk '{s+=$1}END{print s+0}')
  pt=$(grep -hcE "$TASK_RE" "$parent"/*/"$TASKS_FILE" 2>/dev/null | awk '{s+=$1}END{print s+0}')
  printf '\n  %s%s%s  %s%s%s  %s/%s tasks\n' "$BOLD" "$agg" "$RST" "$GRN" "$(bar "$pd" "$pt" 16)" "$RST" "$pd" "$pt"

  render_inbox_line
  footer_nav "$(dir_token "$dir")" "$(dir_token "$ptr_dir")"
}

group_row() {  # one child row inside a group view / the list view
  local d="$1" lvl="$2" namew="$3" barw="$4" ind="$5" ptr="$6"
  local slug num name mk dn tt go=0
  slug="$(basename "$d")"; num="$(slug_num "$lvl" "$slug")"; name="$(slug_name "$lvl" "$slug")"
  if [ "$lvl" -eq "$NLEV" ]; then
    set -- $(count_file "$d/$TASKS_FILE" "$TASK_RE"); dn=$1; tt=$2
    if [ -f "$d/GAPS.md" ]; then set -- $(count_file "$d/GAPS.md" "$GAP_RE"); go=$(( $2 - $1 )); fi
  else
    set -- $(count_tree "$d"); dn=$1; tt=$2
  fi
  case "$ptr" in
    "$d"|"$d"/*) mk="${CYN}▸${RST}" ;;
    *) if [ "$dn" = "$tt" ] && [ "$tt" -gt 0 ]; then mk="${GRN}✓${RST}"; else mk="${DIM}·${RST}"; fi ;;
  esac
  printf '%s  %s %s%s %-*s %s%s%s %s%s/%s%s' "$ind" "$mk" "$(ltr "$lvl")" "$num" "$namew" "$(printf '%s' "$name" | cut -c1-"$namew")" "$GRN" "$(bar "$dn" "$tt" "$barw")" "$RST" "$DIM" "$dn" "$tt" "$RST"
  [ "$go" -gt 0 ] && printf ' %s+%sg%s' "$YEL" "$go" "$RST"
  printf '\n'
}

render_group() {
  local dir="$1" cols; cols=$(cols_now)
  local lvl i seg d
  lvl="$(dir_level "$dir")"
  i=1
  while [ "$i" -lt "$lvl" ]; do
    seg="$(path_seg "$dir" "$i")"
    printf '  %s%s %s · %s%s\n' "$DIM" "$(lbl "$i")" "$(slug_num "$i" "$seg")" "$(slug_name "$i" "$seg" | titlecase)" "$RST"
    i=$((i+1))
  done
  seg="$(path_seg "$dir" "$lvl")"
  printf '  %s%s %s · %s%s\n' "$BOLD" "$(lbl "$lvl")" "$(slug_num "$lvl" "$seg")" "$(slug_name "$lvl" "$seg" | titlecase)" "$RST"
  rule $(( cols - 2 ))
  local ptr; ptr="$(ptr_leaf)"
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    group_row "$d" $((lvl+1)) 22 8 "" "$ptr"
  done < <(kids "$dir" $((lvl+1)))
  render_inbox_line
  footer_nav "$(dir_token "$dir")" "$(dir_token "$ptr")"
}

render_summary() {
  local dir="$1" cols; cols=$(cols_now)
  local lvl slug; lvl="$(dir_level "$dir")"; slug="$(basename "$dir")"
  printf '  %s%s %s · %s%s  %s(summary only)%s\n' "$BOLD" "$(lbl "$lvl")" "$(slug_num "$lvl" "$slug")" "$(slug_name "$lvl" "$slug" | titlecase)" "$RST" "$DIM" "$RST"
  rule $(( cols - 2 ))
  if [ -f "$dir/SUMMARY.md" ]; then
    grep -E '^- ' "$dir/SUMMARY.md" | sed -E "s/^- /  ${DIM}·${RST} /" | cut -c1-$(( cols + 12 ))
  else
    printf '  %sno SUMMARY.md%s\n' "$DIM" "$RST"
  fi
  printf '\n  %sNot yet expanded into %s%s\n' "$DIM" "$TASKS_FILE" "$RST"
  footer_nav "$(dir_token "$dir")" "$(dir_token "$(ptr_leaf)")"
}

render_list_level() {  # recursive tree: $1=parent dir  $2=level  $3=indent
  local parent="$1" lvl="$2" ind="$3"
  local d slug num name dn tt ptr="$4"
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    if [ "$lvl" -eq "$NLEV" ]; then
      group_row "$d" "$lvl" 20 6 "$ind" "$ptr"
    else
      slug="$(basename "$d")"; num="$(slug_num "$lvl" "$slug")"; name="$(slug_name "$lvl" "$slug" | titlecase)"
      if [ -z "$(kids "$d" $((lvl+1)) | head -1)" ]; then
        printf '\n%s  %s%s%s · %s%s  %s— summary only%s\n' "$ind" "$BOLD" "$(ltr "$lvl")$num" "$RST" "$name" "$RST" "$DIM" "$RST"
      else
        set -- $(count_tree "$d"); dn=$1; tt=$2
        printf '\n%s  %s%s%s · %s%s  %s%s/%s%s\n' "$ind" "$BOLD" "$(ltr "$lvl")$num" "$RST" "$name" "$RST" "$DIM" "$dn" "$tt" "$RST"
        render_list_level "$d" $((lvl+1)) "$ind  " "$ptr"
      fi
    fi
  done < <(kids "$parent" "$lvl")
}

render_list() {
  local ptr; ptr="$(ptr_leaf)"
  render_list_level "$TASKS_ROOT" 1 "" "$ptr"
  render_inbox_line
  printf '\n'; nav_hint
}

render_top() {  # altitude view -1: every top-level entry, current marked
  local ptr d; ptr="$(ptr_leaf)"
  while IFS= read -r d; do
    [ -z "$d" ] && continue
    group_row "$d" 1 22 8 "" "$ptr"
  done < <(lvl_dirs 1)
  render_inbox_line
  footer_nav "-1" "$(dir_token "$ptr")"
}

render_dispatch() {
  local sel="$1" r kind arg k glbl
  r="$(resolve "$sel")"; kind="${r%%	*}"; arg="${r#*	}"
  k="$(level_sel "$(lc "$sel")")"   # altitude views headline the level being listed
  case "$kind" in
    LEAF)    header "status"; render_leaf "$arg" ;;
    GROUP)
      if [ -n "$k" ]; then glbl="$(lc "$(lbl "$k")")s"; else glbl="$(lc "$(lbl "$(dir_level "$arg")")")"; fi
      header "$glbl"; render_group "$arg" ;;
    SUMMARY) header "$(lc "$(lbl "$(dir_level "$arg")")")"; render_summary "$arg" ;;
    TOP)     header "$(lc "$(lbl 1)")s"; render_top ;;
    LIST)    header "overview"; render_list ;;
    *)       header "status"; printf '  %s⚠ %s%s\n' "$YEL" "$arg" "$RST"; printf '  %stry: projstatus ls%s\n' "$DIM" "$RST" ;;
  esac
}

# --- `projstatus now`: plain-text orientation for new sessions/agents --------
first_open_task() {  # "ID: Title" of the first task in $1 whose status isn't [x]
  awk -v hdr="$TASK_RE" '
    $0 ~ hdr { h=$0; sub(/^#+[ ]+/,"",h); cand=h; next }
    /^## /   { cand="" }
    cand!="" && /\*\*Status:\*\*/ { if ($0 !~ /\[x\]/) { print cand; exit } cand="" }
  ' "$1" 2>/dev/null
}

cmd_now() {
  local d tok task file c
  d="$(ptr_leaf)"
  [ -z "$d" ] && { printf 'pointer: none (no %s folders under %s)\n' "$(lc "$LEAF_LBL")" "$TASKS_ROOT"; exit 1; }
  tok="$(dir_token "$d")"
  printf 'pointer: %s  %s\n' "$tok" "$d"
  printf 'state: %s\n' "$(pointer_state)"
  file="$d/$TASKS_FILE"
  task="$(first_open_task "$file")"
  if [ -z "$task" ]; then
    while IFS= read -r c; do
      task="$(first_open_task "$c/$TASKS_FILE")"
      [ -n "$task" ] && { file="$c/$TASKS_FILE"; break; }
    done < <(leaf_dirs)
    [ -n "$task" ] && printf 'note: %s is complete — the next open task is in %s\n' "$tok" "$(dir_token "$(dirname "$file")")"
  fi
  if [ -n "$task" ]; then
    printf 'next-task: %s  %s\n' "${task%%:*}" "$(printf '%s' "${task#*:}" | sed 's/^ *//')"
    printf 'file: %s\n' "$file"
  else
    printf 'next-task: none (all tasks complete)\n'
  fi
}

current_view() { local v; v="$(cat "$VIEW_FILE" 2>/dev/null)"; [ -z "$v" ] && v="pointer"; printf '%s' "$v"; }
clear_screen() { tput clear 2>/dev/null || printf '\033[2J\033[3J\033[H'; }

handle_key() {
  case "$1" in
    n|N|' ') write_view next    || true ;;
    p|P)     write_view prev    || true ;;
    c|C|.)   write_view pointer || true ;;
    a|A)     write_view ls      || true ;;
    [1-9])   write_view "-$1"   || true ;;
    r|R)     : ;;
    g|G)     return 3 ;;
    q|Q)     return 2 ;;
    *)       return 1 ;;
  esac
  return 0
}

usage() {
  awk 'NR>2 && !/^#/ {exit} NR>2 {sub(/^# ?/,""); print}' "$0"
}

self_repo() {  # the checkout this command runs from (follows the install symlink)
  local self="$0" dir
  while [ -L "$self" ]; do
    dir="$(cd "$(dirname "$self")" && pwd)"
    self="$(readlink "$self")"
    case "$self" in /*) ;; *) self="$dir/$self" ;; esac
  done
  ( cd "$(dirname "$self")" && git rev-parse --show-toplevel 2>/dev/null )
}

cmd_update() {
  local repo before after
  repo="$(self_repo)"
  if [ -z "$repo" ]; then
    printf 'projstatus was not installed from a git checkout — reinstall with:\n'
    printf '  git clone https://github.com/alecmandla/projstatus\n'
    exit 1
  fi
  before="$(git -C "$repo" rev-parse --short HEAD)"
  if ! git -C "$repo" pull --ff-only; then
    printf '⚠ could not fast-forward %s — update it by hand\n' "$repo"
    exit 1
  fi
  after="$(git -C "$repo" rev-parse --short HEAD)"
  if [ "$before" = "$after" ]; then
    printf 'projstatus %s — already up to date (%s)\n' "$VERSION" "$repo"
  else
    printf 'updated %s → %s:\n' "$before" "$after"
    git -C "$repo" log --oneline "${before}..${after}" | sed 's/^/  /'
    printf 'now: projstatus %s\n' "$(sed -n 's/^VERSION="\(.*\)"$/\1/p' "$repo/projstatus")"
  fi
}

# =============================== main ========================================
case "${1:-}" in
  help|--help|-h) usage ;;
  version|--version|-v) printf 'projstatus %s\n' "$VERSION" ;;
  update) cmd_update ;;
  now) cmd_now ;;
  next|prev)
    printf '%s moves the live pane — use:  projstatus view %s   (or press n/p in the pane)\n' "$1" "$1"
    printf 'for plain-text orientation, use:  projstatus now\n'
    exit 1 ;;
  view)
    sel="${2:-pointer}"
    if write_view "$sel"; then
      tok="$(cat "$VIEW_FILE")"
      printf '%spane → %s%s%s\n' "$DIM" "$RST$MAG" "$tok" "$RST"
      [ "$tok" = "pointer" ] && printf '%s  (following the live pointer: %s)%s\n' "$DIM" "$(dir_token "$(ptr_leaf)")" "$RST"
    else
      printf '%s⚠ unknown selector: %s%s\n' "$YEL" "$sel" "$RST"; exit 1
    fi
    ;;
  pane)
    if [ -n "${SUPACODE_TAB_ID:-}" ]; then
      supacode surface split -d v -i "projstatus --watch" >/dev/null 2>&1
      printf 'opened a projstatus pane — click it and press q to close, or close it in the UI\n'
    else
      printf 'Not inside Supacode. In a terminal split/pane, run:  projstatus --watch\n'
    fi
    ;;
  watch|--watch|-w)
    PANE=1; interval="$REFRESH"
    do_render() {
      PROJSTATUS_COLS=$(tput cols 2>/dev/null || echo 56)
      local frame; frame="$(render_dispatch "$(current_view)")"
      if [ "${PROJSTATUS_NO_CLEAR:-}" = 1 ]; then echo "----------------- (refresh) -----------------"; printf '%s\n' "$frame"; return; fi
      local body; body="$(printf '%s\n' "$frame" | sed $'s/$/\033[K/')"
      printf '%s' $'\033[?25l\033[H'"$body"$'\033[J\033[?25h'
    }
    printf '\033[2J\033[H'
    do_render
    if [ -t 0 ] || [ "${PROJSTATUS_FORCE_TTY:-}" = 1 ]; then
      while true; do
        if IFS= read -r -s -n 1 -t "$interval" key; then
          [ "$key" = $'\033' ] && { IFS= read -r -s -n 2 -t 1 _ 2>/dev/null; do_render; continue; }
          handle_key "$key"; rc=$?
          if [ "$rc" = 2 ]; then clear_screen; printf '  projstatus closed.  restart:  projstatus --watch\n'; exit 0; fi
          if [ "$rc" = 3 ]; then
            printf '\n  %sgo to%s (e.g. %s2, %s, -2, pointer) — then Enter: ' "$BOLD" "$RST" "$(ltr 1)" "$(sel_example)"
            IFS= read -r sel || sel=""
            [ -n "$sel" ] && { write_view "$sel" || true; }
          fi
          do_render
        else
          rc=$?
          if [ "$rc" -gt 128 ]; then do_render
          elif [ "${PROJSTATUS_FORCE_TTY:-}" = 1 ]; then break
          else sleep "$interval"; do_render; fi
        fi
      done
    else
      while true; do sleep "$interval"; do_render; done
    fi
    ;;
  *)
    render_dispatch "${1:-}" ;;
esac
